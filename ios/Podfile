# WorkoutSystem — CocoaPods Dependencies
# Note: SQLite3 on iOS can be used directly via the system framework.
# This Podfile is optional — the app works without it using raw sqlite3 C API.
#
# To install dependencies:
#   pod install
#   open WorkoutSystem.xcworkspace

platform :ios, '17.0'
use_frameworks!

target 'WorkoutSync' do
  # SQLite.swift — Clean Swift wrapper for SQLite (optional, currently using raw C API)
  # pod 'SQLite.swift', '~> 0.15.0'

  # SnapKit — Auto Layout DSL for Swift (optional, currently using SwiftUI)
  # pod 'SnapKit', '~> 5.7.0'

  target 'WorkoutSyncTests' do
    inherit! :search_paths
  end
end

target 'WatchWorkout' do
  # Watch app has no external CocoaPods dependencies
  # All functionality uses Apple's native frameworks (HealthKit, WatchConnectivity)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
      config.build_settings['WATCHOS_DEPLOYMENT_TARGET'] = '10.0'
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
    end
  end
end
